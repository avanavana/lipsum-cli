parse_positive_spec () {
  local value="$1"
  local min_ref="$2"
  local max_ref="$3"
  local label="$4"
  local min_value=''
  local max_value=''

  if [[ $value == <-> ]]; then
    min_value=$value
    max_value=$value
  elif [[ $value == <->-<-> ]]; then
    min_value="${value%%-*}"
    max_value="${value##*-}"
  else
    return 1
  fi

  if (( min_value < 1 || max_value < 1 )); then
    die "$label values must be greater than zero"
  fi

  if (( min_value > max_value )); then
    die "$label range minimum cannot be greater than maximum"
  fi

  typeset -g "$min_ref=$min_value"
  typeset -g "$max_ref=$max_value"
  return 0
}

ensure_positive_integer () {
  local value="$1"
  local label="$2"

  [[ $value == <-> ]] || die "$label must be a positive integer"
  (( value > 0 )) || die "$label must be greater than zero"
}

rand_range () {
  local -i min=$1
  local -i max=$2

  if (( max <= min )); then
    REPLY=$min
    return
  fi

  REPLY=$(( RANDOM % (max - min + 1) + min ))
}

capitalize_first () {
  local text="$1"

  if [[ -z $text ]]; then
    print -- ''
    return
  fi

  print -- "${(U)text[1]}${text[2,-1]}"
}

format_text () {
  local text="$1"

  case "$case_mode" in
    lower)
      text="${(L)text}"
      ;;
    upper)
      text="${(U)text}"
      ;;
    title)
      text="${(C)${(L)text}}"
      ;;
    normal)
      text="$(capitalize_first "${(L)text}")"
      ;;
    *)
      die "Unknown case mode: $case_mode"
      ;;
  esac

  case "$punctuation_mode" in
    none)
      :
      ;;
    period)
      if ! text_has_terminal_punctuation "$text"; then
        text="$(append_terminal_punctuation "$text" '.')"
      fi
      ;;
    end)
      if ! text_has_terminal_punctuation "$text"; then
        random_terminal_punctuation
        text="$(append_terminal_punctuation "$text" "$REPLY")"
      fi
      ;;
    all)
      text="$(apply_internal_punctuation "$text")"
      if ! text_has_terminal_punctuation "$text"; then
        random_terminal_punctuation
        text="$(append_terminal_punctuation "$text" "$REPLY")"
      fi
      ;;
    *)
      die "Unknown punctuation_mode: $punctuation_mode"
      ;;
  esac

  print -- "$text"
}

valid_punctuation_mode () {
  case "$1" in
    period|end|all|none)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

valid_output_format () {
  case "$1" in
    plain|html|markdown|json|ndjson)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

read_optional_punctuation_mode () {
  local next_arg="$1"

  if [[ -n $next_arg ]] && valid_punctuation_mode "$next_arg"; then
    punctuation_mode="$next_arg"
    punctuation_option_set=1
    return 0
  fi

  punctuation_mode='all'
  punctuation_option_set=1
  return 1
}

token_is_emoji_token () {
  local token="$1"

  [[ -n ${emoji_lookup[$token]} ]]
}

text_has_terminal_punctuation () {
  local text="$1"
  local -a tokens=()
  local -i index=0

  [[ -n $text ]] || return 1

  tokens=( ${(s: :)text} )
  index=${#tokens[@]}

  while (( index > 0 )); do
    if token_is_emoji_token "${tokens[index]}"; then
      (( index-- ))
      continue
    fi

    break
  done

  if (( index <= 0 )); then
    return 1
  fi

  [[ ${tokens[index]}[-1] == [.!?] ]]
}

append_terminal_punctuation () {
  local text="$1"
  local mark="$2"
  local -a tokens=()
  local -i index=0

  if [[ -z $text ]]; then
    print -- "$mark"
    return
  fi

  tokens=( ${(s: :)text} )
  index=${#tokens[@]}

  while (( index > 0 )); do
    if token_is_emoji_token "${tokens[index]}"; then
      (( index-- ))
      continue
    fi

    break
  done

  if (( index <= 0 )); then
    print -- "$text$mark"
    return
  fi

  if (( index == ${#tokens[@]} )); then
    print -- "$text$mark"
    return
  fi

  tokens[index]="${tokens[index]}$mark"
  print -- "${(j: :)tokens}"
}

random_terminal_punctuation () {
  local -a marks=( '.' '.' '.' '.' '.' '.' '!' '?' )

  rand_range 1 "${#marks[@]}"
  REPLY="${marks[REPLY]}"
}

apply_internal_punctuation () {
  local text="$1"
  local -a tokens=()
  local -A used_positions=()
  local -i token_count=0
  local -i punctuation_count=0
  local -i position=0
  local -i style=0

  tokens=( ${(s: :)text} )
  token_count=${#tokens[@]}

  if (( token_count < 4 )); then
    print -- "$text"
    return
  fi

  punctuation_count=1
  if (( token_count >= 12 )); then
    punctuation_count=$(( 1 + RANDOM % 2 ))
  fi

  while (( punctuation_count > 0 )); do
    rand_range 2 "$(( token_count - 1 ))"
    position=$REPLY

    if [[ -n ${used_positions[$position]} ]]; then
      continue
    fi

    if token_is_emoji_token "${tokens[position]}"; then
      continue
    fi

    used_positions[$position]=1
    rand_range 1 10
    style=$REPLY

    case "$style" in
      1|2|3|4|5)
        tokens[position]="${tokens[position]},"
        ;;
      6|7)
        tokens[position]="(${tokens[position]})"
        ;;
      8)
        tokens[position]="—${tokens[position]}"
        ;;
      9|10)
        tokens[position]="${tokens[position]}-"
        ;;
    esac

    (( punctuation_count-- ))
  done

  print -- "${(j: :)tokens}"
}

is_short_command_char () {
  case "$1" in
    c|C|w|W|l|L|s|S|p|P)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_content_command_name () {
  case "$1" in
    c|C|char|chars|character|characters|w|W|word|words|l|L|line|lines|s|S|sent|sents|sentence|sentences|p|P|para|paras|paragraph|paragraphs|template|tpl|tmpl)
