typeset resolved_source=''
typeset custom_source_text=''
typeset custom_source_file=''
typeset save_source_name=''
typeset dictstring=''
typeset -a dict=()
typeset -a dict_words=()

typeset content_command=''
typeset action_command=''
typeset -i command_set=0
typeset -i action_set=0
typeset -i source_set=0
typeset -i custom_source_set=0
typeset -i count_set=0
typeset -i count_min=0
typeset -i count_max=0
typeset -i count=0
typeset case_mode='normal'
typeset -i punc=1
typeset -i bullets=0
typeset -i ordered_list=0
typeset bulletchar=''
typeset ordered_formula=''
typeset -i bulletchar_set=0
typeset -i ordered_formula_set=0
typeset -i range_set=0
typeset -i range_min=0
typeset -i range_max=0
typeset -i word_length_filter_set=0
typeset -a filtered_words=()
typeset -i paragraph_sentence_word_min=0
typeset -i paragraph_sentence_word_max=0
