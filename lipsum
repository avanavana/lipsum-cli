EOF
}

ensure_config_directory () {
  local config_dir="${config_path:h}"
  mkdir -p "$config_dir" || die "Could not create config directory: $config_dir"
}

init_config () {
  ensure_config_directory

  if [[ -e $config_path ]]; then
    print -- "Config already exists at $config_path"
    exit 0
  fi

  default_config_contents >| "$config_path" || die "Could not write config file: $config_path"
  print -- "Created config file at $config_path"
  exit 0
}

open_config () {
  local editor="${VISUAL:-${EDITOR:-vi}}"
  local quoted_path="${(q)config_path}"

  ensure_config_directory

  if [[ ! -e $config_path ]]; then
    default_config_contents >| "$config_path" || die "Could not write config file: $config_path"
  fi

  zsh -fc "setopt nonomatch; $editor $quoted_path" || die "Editor command failed"

  load_config
  validate_config
  print -- "Config is valid: $config_path"
  exit 0
}

load_config () {
  if [[ -r $config_path ]]; then
    source "$config_path"
  fi
}

normalize_source_name () {
  local name="$1"
  print -- "${(L)name}"
}

built_in_source_name () {
  local name="$(normalize_source_name "$1")"

  case "$name" in
    lorem|hipster|tech|pirate|food|corporate|es|fr|de)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

source_display_title () {
  local name="$(normalize_source_name "$1")"

  case "$name" in
    lorem)
      REPLY='Lorem Ipsum'
      ;;
    hipster)
      REPLY='Hipster Ipsum'
      ;;
    tech)
      REPLY='Tech Ipsum'
      ;;
    pirate)
      REPLY='Pirate Ipsum'
      ;;
    food)
      REPLY='Food Ipsum'
      ;;
    corporate)
      REPLY='Corporate Ipsum'
      ;;
    es)
      REPLY='Spanish Ipsum'
      ;;
    fr)
      REPLY='French Ipsum'
      ;;
    de)
      REPLY='German Ipsum'
      ;;
    *)
      REPLY="${(C)${(L)${name//-/ }}}"
      REPLY="${REPLY//_/ }"
      ;;
  esac
}

source_file_path () {
  local name="$(normalize_source_name "$1")"
  REPLY="$source_dir/$name.words"
}

template_file_path () {
  local name="$(normalize_source_name "$1")"
  REPLY="$template_dir/$name.tpl"
}

bundled_template_file_path () {
  local name="$(normalize_source_name "$1")"
  REPLY="$bundled_template_dir/$name.tpl"
}

template_exists () {
  local name="$(normalize_source_name "$1")"
  local template_file=''
  local bundled_template_file=''

  [[ -n $name ]] || return 1
  template_file_path "$name"
  template_file="$REPLY"
  bundled_template_file_path "$name"
  bundled_template_file="$REPLY"

  [[ -r $template_file || -r $bundled_template_file ]]
}

resolve_template_path () {
  local name="$(normalize_source_name "$1")"
  local template_file=''
  local bundled_template_file=''

  template_file_path "$name"
  template_file="$REPLY"
  bundled_template_file_path "$name"
  bundled_template_file="$REPLY"

  if [[ -r $template_file ]]; then
    REPLY="$template_file"
    return
  fi

  if [[ -r $bundled_template_file ]]; then
    REPLY="$bundled_template_file"
    return
  fi

  die "Template not found: $name"
}

template_display_title () {
  local name="$1"
  local path=''
  local title=''

  resolve_template_path "$name"
  path="$REPLY"

  while IFS= read -r line; do
    if [[ $line =~ '^# title:[[:space:]]*(.+)$' ]]; then
      title="$match[1]"
      break
    fi

    [[ $line == '#'* ]] || break
  done < "$path"

  if [[ -n $title ]]; then
    REPLY="$title"
    return
  fi

  REPLY="${(C)${(L)${name//-/ }}}"
}

available_template_names () {
  local -a names=()
  local -A seen=()
  local file=''
  local base=''

  for file in "$template_dir"/*.tpl(N); do
    base="${file:t:r}"
    base="$(normalize_source_name "$base")"

    if [[ -z ${seen[$base]} ]]; then
      names+=( "$base" )
      seen[$base]=1
    fi
  done

  for file in "$bundled_template_dir"/*.tpl(N); do
    base="${file:t:r}"
    base="$(normalize_source_name "$base")"

    if [[ -z ${seen[$base]} ]]; then
      names+=( "$base" )
      seen[$base]=1
    fi
  done

  REPLY="${(j: :)names}"
}

bundled_source_file_path () {
  local name="$(normalize_source_name "$1")"

  if [[ $name == 'lorem' ]]; then
    REPLY="$bundled_dictionary_path"
    return
  fi

  REPLY="$bundled_source_dir/$name.words"
}

valid_source_name () {
  local name="$(normalize_source_name "$1")"
  [[ -n $name && $name =~ '^[a-z0-9][a-z0-9_-]*$' ]]
}

normalize_corpus_text () {
  local text="$1"

  text="${text//$'\r'/ }"
  text="${text//$'\n'/ }"
  text="${text//$'\t'/ }"

  while [[ $text == *'  '* ]]; do
    text="${text//  / }"
  done

  text="${text#"${text%%[![:space:]]*}"}"
  text="${text%"${text##*[![:space:]]}"}"

  print -- "$text"
}

normalize_emoji_charset () {
  local text="$1"

  text="${text//$'\r'/ }"
  text="${text//$'\n'/ }"
  text="${text//$'\t'/ }"

  while [[ $text == *'  '* ]]; do
    text="${text//  / }"
  done

  text="${text#"${text%%[![:space:]]*}"}"
  text="${text%"${text##*[![:space:]]}"}"

  print -- "$text"
}

load_emoji_pool () {
  local -i required=${1:-0}

  emoji_charset="$(normalize_emoji_charset "$emoji_charset")"
  emoji_pool=( ${(s: :)emoji_charset} )
  emoji_lookup=()

  local emoji=''
  for emoji in "${emoji_pool[@]}"; do
    emoji_lookup[$emoji]=1
  done

  if (( required )) && (( ${#emoji_pool[@]} == 0 )); then
    die 'emoji_charset cannot be empty'
  fi
}

source_exists () {
  local name="$(normalize_source_name "$1")"
  local source_file=''
  local bundled_source_file=''

  if [[ -z $name ]]; then
    return 1
  fi

  source_file_path "$name"
  source_file="$REPLY"
  bundled_source_file_path "$name"
  bundled_source_file="$REPLY"

  if [[ $name == 'lorem' ]]; then
    if [[ -n $dictionary_override ]]; then
      [[ -r $dictionary_override ]] || die "Dictionary file not found: $dictionary_override"
      return 0
    fi

    [[ -r $source_file || -r $legacy_dictionary_path || -r $bundled_source_file ]] && return 0
    return 1
  fi

  [[ -r $source_file || -r $bundled_source_file ]]
}

resolve_source_dictionary_path () {
  local name="$(normalize_source_name "$1")"
  local source_file=''
  local bundled_source_file=''

  source_file_path "$name"
  source_file="$REPLY"
  bundled_source_file_path "$name"
  bundled_source_file="$REPLY"

  if [[ $name == 'lorem' ]]; then
    if [[ -n $dictionary_override ]]; then
      [[ -r $dictionary_override ]] || die "Dictionary file not found: $dictionary_override"
      dictionary_path="$dictionary_override"
      return
    fi

    if [[ -r $source_file ]]; then
      dictionary_path="$source_file"
      return
    fi

    if [[ -r $legacy_dictionary_path ]]; then
      dictionary_path="$legacy_dictionary_path"
      return
    fi

    if [[ -r $bundled_source_file ]]; then
      dictionary_path="$bundled_source_file"
      return
    fi
  else
    if [[ -r $source_file ]]; then
      dictionary_path="$source_file"
      return
    fi

    if [[ -r $bundled_source_file ]]; then
      dictionary_path="$bundled_source_file"
      return
    fi
  fi

  die "Source not found: $name"
}

available_source_names () {
  local -a names=()
  local -A seen=()
  local file=''
  local base=''

  if source_exists 'lorem'; then
    names+=( 'lorem' )
    seen[lorem]=1
  fi

  for file in "$source_dir"/*.words(N); do
    base="${file:t:r}"
    base="$(normalize_source_name "$base")"

    if [[ -z ${seen[$base]} ]]; then
      names+=( "$base" )
      seen[$base]=1
    fi
  done

  for file in "$bundled_source_dir"/*.words(N); do
    base="${file:t:r}"
    base="$(normalize_source_name "$base")"

    if [[ -z ${seen[$base]} ]]; then
      names+=( "$base" )
      seen[$base]=1
    fi
  done

  REPLY="${(j: :)names}"
}

print_available_sources () {
  local default_name="$(normalize_source_name "$default_source")"
  local source_name=''
  local -a names=()
  local -a built_in_names=()
  local -a custom_names=()
  local -A available=()

  available_source_names
  names=( ${(s: :)REPLY} )

  (( ${#names[@]} > 0 )) || die "No sources are available. Install bundled sources into $source_dir first."

  for source_name in "${names[@]}"; do
    available[$source_name]=1
  done

  for source_name in lorem hipster tech pirate food corporate es fr de; do
    if [[ -n ${available[$source_name]} ]]; then
      built_in_names+=( "$source_name" )
    fi
  done

  for source_name in "${names[@]}"; do
    if ! built_in_source_name "$source_name"; then
      custom_names+=( "$source_name" )
    fi
  done

  print -- 'Available Sources'
  print -- ''
  print_source_section 'Built-In Sources' "$default_name" "${built_in_names[@]}"
  print_source_section 'Imported Sources' "$default_name" "${custom_names[@]}"
  print -- "Default source: $default_name"

  exit 0
}

source_sample_paragraph () {
  local source_name="$(normalize_source_name "$1")"
  local -i saved_emoji_active=$emoji_active

  resolve_source_dictionary_path "$source_name"
  load_dictionary

  emoji_active=0
  count=1
  range_min=2
  range_max=2
  paragraph_sentence_word_min=7
  paragraph_sentence_word_max=11
  build_paragraphs
  emoji_active=$saved_emoji_active
}

print_source_section () {
  local heading="$1"
  local default_name="$2"
  shift 2

  local -a names=( "$@" )
  local source_name=''
  local title=''
  local sample=''
  local default_label=''

  print -- "$heading:"

  if (( ${#names[@]} == 0 )); then
    print -- '  (none)'
    print -- ''
    return
  fi

  for source_name in "${names[@]}"; do
    source_display_title "$source_name"
    title="$REPLY"
    default_label=''

    if [[ $source_name == $default_name ]]; then
      default_label=' [default]'
    fi

    source_sample_paragraph "$source_name"
    sample="$REPLY"

    print -- "- $title (${source_name})$default_label"
    print -- "  $sample"
    print -- ''
  done
}

load_template_body () {
  local name="$(normalize_source_name "$1")"
  local path=''
  local line=''
  local body=''
  local -i body_started=0

  resolve_template_path "$name"
  path="$REPLY"

  while IFS= read -r line || [[ -n $line ]]; do
    if (( ! body_started )) && [[ $line == '#'* ]]; then
      continue
    fi

    body_started=1

    if [[ -n $body ]]; then
      body+=$'\n'
    fi

    body+="$line"
  done < "$path"

  [[ -n $body ]] || die "Template is empty: $name"
  REPLY="$body"
}

trim_spaces () {
  local text="$1"
  text="${text#"${text%%[![:space:]]*}"}"
  text="${text%"${text##*[![:space:]]}"}"
  print -- "$text"
}

template_positive_spec () {
  local spec="$1"
  local min_ref="$2"
  local max_ref="$3"
  local label="$4"

  if [[ -z $spec ]]; then
    typeset -g "$min_ref=1"
    typeset -g "$max_ref=1"
    return
  fi

  spec="$(trim_spaces "$spec")"
  parse_positive_spec "$spec" "$min_ref" "$max_ref" "$label" || die "Invalid $label in template: $spec"
}

template_number () {
  local spec="$1"
  local -i spec_min=0
  local -i spec_max=0

  template_positive_spec "$spec" spec_min spec_max 'number'
  rand_range "$spec_min" "$spec_max"
}

template_words () {
  local spec="$1"
  local -i spec_min=0
  local -i spec_max=0

  template_positive_spec "$spec" spec_min spec_max 'words'
  rand_range "$spec_min" "$spec_max"
  random_words "$REPLY"
}

template_sentence () {
  local spec="$1"
  local -i spec_min=0
  local -i spec_max=0

  template_positive_spec "$spec" spec_min spec_max 'sentence'
  rand_range "$spec_min" "$spec_max"
  random_sentence "$REPLY"
}

template_choice () {
  local spec="$1"
  local -a choices=()

  spec="$(trim_spaces "$spec")"
  [[ -n $spec ]] || die 'choice() in templates requires at least one option'
  choices=( ${(s:|:)spec} )
  (( ${#choices[@]} > 0 )) || die 'choice() in templates requires at least one option'
  rand_range 1 "${#choices[@]}"
  REPLY="$(trim_spaces "${choices[REPLY]}")"
}

template_emoji () {
  local spec="$1"
  local -i spec_min=0
  local -i spec_max=0
  local -i emoji_count=0
  local -a emojis=()

  if (( ${#emoji_pool[@]} == 0 )); then
    load_emoji_pool 1
  fi

  template_positive_spec "$spec" spec_min spec_max 'emoji'
  rand_range "$spec_min" "$spec_max"
  emoji_count=$REPLY

  while (( emoji_count > 0 )); do
    random_emoji
    emojis+=( "$REPLY" )
    (( emoji_count-- ))
  done

  REPLY="${(j: :)emojis}"
}

render_template_expression () {
  local expression="$1"
  local name=''
  local args=''

  expression="$(trim_spaces "$expression")"

  if [[ $expression =~ '^([A-Za-z][A-Za-z0-9_-]*)(\((.*)\))?$' ]]; then
    name="${(L)match[1]}"
    args="$match[3]"
  else
    die "Invalid template expression: $expression"
  fi

  case "$name" in
    words|word)
      template_words "$args"
      ;;
    sentence|sent)
      template_sentence "$args"
      ;;
    number|int)
      template_number "$args"
      ;;
    choice|pick)
      template_choice "$args"
      ;;
    emoji)
      template_emoji "$args"
      ;;
    *)
      die "Unknown template expression: $name"
      ;;
  esac
}

render_template_text () {
  local text="$1"
  local output=''
  local prefix=''
  local suffix=''
  local expression=''

  while [[ $text == *'{{'* ]]; do
    prefix="${text%%\{\{*}"
    output+="$prefix"
    suffix="${text#*\{\{}"

    if [[ $suffix != *'}}'* ]]; then
      die "Unclosed template expression in template '$selected_template'"
    fi

    expression="${suffix%%\}\}*}"
    render_template_expression "$expression"
    output+="$REPLY"
    text="${suffix#*\}\}}"
  done

  output+="$text"
  REPLY="$output"
}

template_sample_output () {
  local name="$(normalize_source_name "$1")"
  local saved_template="$selected_template"
  local -i saved_count=$count
  local saved_text="$generated_text"
  local -a saved_items=( "${generated_items[@]}" )
  local -i saved_emoji_active=$emoji_active
  local saved_dictionary_path="$dictionary_path"
  local sample_source=''

  if (( ${#dict_words[@]} == 0 )); then
    if [[ -n $resolved_source ]]; then
      sample_source="$resolved_source"
    else
      sample_source="$default_source"
    fi
    resolve_source_dictionary_path "$sample_source"
    load_dictionary
  fi

  selected_template="$name"
  count=1
  emoji_active=0
  build_template
  emoji_active=$saved_emoji_active
  selected_template="$saved_template"
  count=$saved_count
  dictionary_path="$saved_dictionary_path"
  generated_text="$saved_text"
  generated_items=( "${saved_items[@]}" )
}

print_template_section () {
  local heading="$1"
  shift

  local -a names=( "$@" )
  local name=''
  local title=''
  local sample=''

  print -- "$heading:"

  if (( ${#names[@]} == 0 )); then
    print -- '  (none)'
    print -- ''
    return
  fi

  for name in "${names[@]}"; do
    template_display_title "$name"
    title="$REPLY"
    template_sample_output "$name"
    sample="$REPLY"
    print -- "- $title (${name})"
    print -- "  $sample"
    print -- ''
  done
}

print_available_templates () {
  local -a names=()
  local -a built_in_names=()
  local -a custom_names=()
  local -A available=()
  local name=''

  available_template_names
  names=( ${(s: :)REPLY} )

  (( ${#names[@]} > 0 )) || die "No templates are available. Create one under $template_dir first."

  for name in "${names[@]}"; do
    available[$name]=1
  done

  for name in conventional-commit email-subject notification apa-citation status-update; do
    if [[ -n ${available[$name]} ]]; then
      built_in_names+=( "$name" )
    fi
  done

  for name in "${names[@]}"; do
    if [[ " ${built_in_names[*]} " != *" $name "* ]]; then
      custom_names+=( "$name" )
    fi
  done

  print -- 'Available Templates'
  print -- ''
  print_template_section 'Built-In Templates' "${built_in_names[@]}"
  print_template_section 'Imported Templates' "${custom_names[@]}"
  exit 0
}

load_dictionary () {
  [[ -n $dictionary_path ]] || die 'No dictionary path resolved'
  [[ -r $dictionary_path ]] || die "Dictionary file not found: $dictionary_path"

  dictstring="$(normalize_corpus_text "$(<"$dictionary_path")")"
  dict=( ${(s: :)dictstring} )
  dict_words=( ${(L)dict[@]} )

  (( ${#dict[@]} > 0 )) || die "Dictionary file is empty: $dictionary_path"
}

load_dictionary_from_text () {
  local source_text="$1"

  dictstring="$(normalize_corpus_text "$source_text")"
  dict=( ${(s: :)dictstring} )
  dict_words=( ${(L)dict[@]} )

  (( ${#dict[@]} > 0 )) || die 'Custom source text did not contain any usable words'
}

save_source_text () {
  local name="$(normalize_source_name "$1")"
  local source_text="$2"
  local source_path=''

  valid_source_name "$name" || die "Invalid source name: $1"
  mkdir -p "$source_dir" || die "Could not create source directory: $source_dir"
  source_file_path "$name"
  source_path="$REPLY"
  print -r -- "$source_text" >| "$source_path" || die "Could not write source file: $source_path"
}

validate_config () {
  is_content_command_name "$default_mode" || die "Invalid default_mode in config: $default_mode"
  [[ $default_mode != 'template' && $default_mode != 'tpl' && $default_mode != 'tmpl' ]] || die 'default_mode cannot be template; use an explicit template name at invocation time'
  default_source="$(normalize_source_name "$default_source")"
  [[ -n $default_source ]] || die 'default_source cannot be empty'

  ensure_positive_integer "$default_word_count" 'default_word_count'
  ensure_positive_integer "$default_character_count" 'default_character_count'
  ensure_positive_integer "$default_line_count" 'default_line_count'
  ensure_positive_integer "$default_sentence_count" 'default_sentence_count'
  ensure_positive_integer "$default_paragraph_count" 'default_paragraph_count'

  parse_positive_spec "$default_line_range" config_line_range_min config_line_range_max 'default_line_range' || die "Invalid default_line_range in config: $default_line_range"
  parse_positive_spec "$default_sentence_range" config_sentence_range_min config_sentence_range_max 'default_sentence_range' || die "Invalid default_sentence_range in config: $default_sentence_range"
  parse_positive_spec "$default_paragraph_range" config_paragraph_range_min config_paragraph_range_max 'default_paragraph_range' || die "Invalid default_paragraph_range in config: $default_paragraph_range"
  parse_positive_spec "$default_word_length_range" config_word_length_min config_word_length_max 'default_word_length_range' || die "Invalid default_word_length_range in config: $default_word_length_range"
  parse_positive_spec "$default_paragraph_sentence_word_range" config_paragraph_sentence_word_min config_paragraph_sentence_word_max 'default_paragraph_sentence_word_range' || die "Invalid default_paragraph_sentence_word_range in config: $default_paragraph_sentence_word_range"

  valid_output_format "$default_format" || die "Invalid default_format in config: $default_format"
  valid_punctuation_mode "$punctuation_mode" || die "Invalid punctuation_mode in config: $punctuation_mode"
  [[ $copy_on_generate == 0 || $copy_on_generate == 1 ]] || die "copy_on_generate must be 0 or 1"
  [[ $emoji_enabled == 0 || $emoji_enabled == 1 ]] || die "emoji_enabled must be 0 or 1"
  load_emoji_pool "$emoji_enabled"

  if (( ! source_set && ! custom_source_set )); then
    source_exists "$default_source" || die "Unknown default_source in config: $default_source"
  fi
}

default_count_for_command () {
  case "$1" in
    characters)
      REPLY=$default_character_count
      ;;
    words)
      REPLY=$default_word_count
      ;;
    lines)
      REPLY=$default_line_count
      ;;
    sentences)
      REPLY=$default_sentence_count
      ;;
    paragraphs)
      REPLY=$default_paragraph_count
      ;;
    template)
      REPLY=1
      ;;
    *)
      die "Unknown command: $1"
      ;;
  esac
}

copy_text () {
  local text="$1"

  if [[ -n $LIPSUM_CLIPBOARD_COMMAND ]]; then
    printf '%s' "$text" | zsh -fc "setopt nonomatch; $LIPSUM_CLIPBOARD_COMMAND" || die "Clipboard command failed"
    return
  fi

  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$text" | pbcopy || die "pbcopy failed"
    return
  fi

  if command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$text" | wl-copy || die "wl-copy failed"
    return
  fi

  if command -v xclip >/dev/null 2>&1; then
    printf '%s' "$text" | xclip -selection clipboard || die "xclip failed"
    return
  fi

  if command -v xsel >/dev/null 2>&1; then
    printf '%s' "$text" | xsel --clipboard --input || die "xsel failed"
    return
  fi

  die "No clipboard command available"
}

emit_output () {
  local text="$1"

  if (( copy_enabled )); then
    copy_text "$text"
  fi

  print -r -- "$text"
}

json_escape () {
  local text="$1"
  text="${text//\\/\\\\}"
  text="${text//\"/\\\"}"
  text="${text//$'\n'/\\n}"
  text="${text//$'\r'/\\r}"
  text="${text//$'\t'/\\t}"
  text="${text//$'\f'/\\f}"
  text="${text//$'\b'/\\b}"
  print -r -- "\"$text\""
}

html_escape () {
  local text="$1"
  text="${text//&/&amp;}"
  text="${text//</&lt;}"
  text="${text//>/&gt;}"
  text="${text//\"/&quot;}"
  print -r -- "$text"
}

strip_line_prefix () {
  local text="$1"

  if (( ordered_list )); then
    print -- "${text#* }"
    return
  fi

  if (( bullets )); then
    print -- "${text#"$bulletchar "}"
    return
  fi

  print -- "$text"
}

render_json_array () {
  local -a items=( "$@" )
  local -a quoted_items=()
  local item=''

  for item in "${items[@]}"; do
    quoted_items+=( "$(json_escape "$item")" )
  done

  print -r -- "[ ${(j:, :)quoted_items} ]"
}

render_html_list () {
  local list_tag="$1"
  shift

  local -a items=( "$@" )
  local item=''
  local output="<$list_tag>"

  for item in "${items[@]}"; do
    item="$(strip_line_prefix "$item")"
    output+=$'\n'
    output+="  <li>$(html_escape "$item")</li>"
  done

  output+=$'\n'
  output+="</$list_tag>"
  print -r -- "$output"
}

render_output () {
  local -a items=( "${generated_items[@]}" )
  local item=''
  local output=''

  case "$output_format" in
    plain)
      print -r -- "$generated_text"
      ;;
    markdown)
      case "$content_command" in
        lines)
          if (( bullets || ordered_list )); then
            print -r -- "$generated_text"
            return
          fi

          for item in "${items[@]}"; do
            if [[ -n $output ]]; then
              output+=$'\n'
            fi
            output+="- $item"
          done
          print -r -- "$output"
          ;;
        template)
          if (( ${#items[@]} <= 1 )); then
            print -r -- "$generated_text"
            return
          fi

          for item in "${items[@]}"; do
            if [[ -n $output ]]; then
              output+=$'\n'
            fi
            output+="- $item"
          done
          print -r -- "$output"
          ;;
        *)
          print -r -- "$generated_text"
          ;;
      esac
      ;;
    html)
      case "$content_command" in
        lines)
          if (( ordered_list )); then
            render_html_list 'ol' "${items[@]}"
          else
            render_html_list 'ul' "${items[@]}"
          fi
          ;;
        paragraphs)
          for item in "${items[@]}"; do
            if [[ -n $output ]]; then
              output+=$'\n'
            fi
            output+="<p>$(html_escape "$item")</p>"
          done
          print -r -- "$output"
          ;;
        words|sentences)
          print -r -- "<p>$(html_escape "$generated_text")</p>"
          ;;
        template)
          if (( ${#items[@]} > 1 )); then
            render_html_list 'ul' "${items[@]}"
          else
            print -r -- "<p>$(html_escape "$generated_text")</p>"
          fi
          ;;
        *)
          print -r -- "<p>$(html_escape "$generated_text")</p>"
          ;;
      esac
      ;;
    json)
      case "$content_command" in
        characters)
          json_escape "$generated_text"
          ;;
        *)
          render_json_array "${items[@]}"
          ;;
      esac
      ;;
    ndjson)
      if [[ $content_command == 'characters' ]]; then
        json_escape "$generated_text"
        return
      fi

      for item in "${items[@]}"; do
        if [[ -n $output ]]; then
          output+=$'\n'
        fi
        output+="$(json_escape "$item")"
      done
      print -r -- "$output"
      ;;
    *)
      die "Unknown output format: $output_format"
      ;;
  esac
}

int_to_roman () {
  local -i number=$1
  local -a values=( 1000 900 500 400 100 90 50 40 10 9 5 4 1 )
  local -a numerals=( M CM D CD C XC L XL X IX V IV I )
  local -i i=1
  local result=''

  while (( i <= ${#values[@]} )); do
    while (( number >= values[i] )); do
      result+="${numerals[i]}"
      number=$(( number - values[i] ))
    done

    (( i++ ))
  done

  REPLY="$result"
}

int_to_alpha () {
  local -i number=$1
  local result=''
  local -i remainder=0

  while (( number > 0 )); do
    remainder=$(( (number - 1) % 26 ))
    result="$(printf "\\$(printf '%03o' $((97 + remainder)))")$result"
    number=$(( (number - 1) / 26 ))
  done

  REPLY="$result"
}

parse_ordered_formula () {
  local formula="$1"
  local prefix=''
  local suffix=''
  local zeros=''
  local kind=''

  ordered_prefix=''
  ordered_suffix=''
  ordered_kind=''
  ordered_width=0

  if [[ $formula =~ '^(.*)%([0]*)([dz])(.*)$' ]]; then
    prefix="$match[1]"
    zeros="$match[2]"
    kind="$match[3]"
    suffix="$match[4]"
    ordered_width=$(( ${#zeros} + 1 ))
  elif [[ $formula =~ '^(.*)%([iIaA])(.*)$' ]]; then
    prefix="$match[1]"
    kind="$match[2]"
    suffix="$match[3]"
    ordered_width=0
  else
    die "Invalid ordered list format: $formula"
  fi

  if [[ $prefix$suffix == *%* ]]; then
    die "Ordered list format may contain only one marker"
  fi

  ordered_prefix="$prefix"
  ordered_suffix="$suffix"
  ordered_kind="$kind"
}

ordered_marker () {
  local -i index=$1
  local value=''
  local -i zero_index=$(( index - 1 ))

  case "$ordered_kind" in
    d)
      value="$(printf "%0*d" "$ordered_width" "$index")"
      ;;
    z)
      value="$(printf "%0*d" "$ordered_width" "$zero_index")"
      ;;
    i)
      int_to_roman "$index"
      value="${(L)REPLY}"
      ;;
    I)
      int_to_roman "$index"
      value="$REPLY"
      ;;
    a)
      int_to_alpha "$index"
      value="$REPLY"
      ;;
    A)
      int_to_alpha "$index"
      value="${(U)REPLY}"
      ;;
    *)
      die "Unknown ordered list marker kind: $ordered_kind"
      ;;
  esac

  REPLY="${ordered_prefix}${value}${ordered_suffix}"
}

apply_line_prefix () {
  local text="$1"
  local -i index=$2

  if (( ordered_list )); then
    ordered_marker "$index"
    print -- "$REPLY $text"
    return
  fi

  if (( bullets )); then
    print -- "$bulletchar $text"
    return
  fi

  print -- "$text"
}

random_emoji () {
  local -i total=${#emoji_pool[@]}

  (( total > 0 )) || die 'No emoji are available in emoji_charset'
  rand_range 1 "$total"
  REPLY="${emoji_pool[REPLY]}"
}

emoji_count_for_length () {
  local -i text_length=$1
  local -i token_count=$2
  local -i emoji_count=0
  local -i remainder=0

  if (( ! emoji_active || token_count <= 0 || ${#emoji_pool[@]} == 0 || text_length <= 0 )); then
    REPLY=0
    return
  fi

  emoji_count=$(( text_length / 140 ))
  remainder=$(( text_length % 140 ))

  if (( remainder > 0 )) && (( RANDOM % 140 < remainder )); then
    (( emoji_count++ ))
  fi

  if (( emoji_count == 0 && text_length >= 30 )) && (( RANDOM % 200 < text_length )); then
    emoji_count=1
  fi

  if (( emoji_count > token_count )); then
    emoji_count=$token_count
  fi

  REPLY=$emoji_count
}

apply_emoji_to_words () {
  local -a words=( "$@" )
  local -i token_count=${#words[@]}
  local joined_words="${(j: :)words}"
  local -i start_index=1
  local -i emoji_count=0
  local -i position=0
  local -A used_positions=()
  local token=''
  local suffix=''
  local emoji=''

  (( token_count > 0 )) || {
    REPLY=''
    return
  }

  emoji_count_for_length "${#joined_words}" "$token_count"
  emoji_count=$REPLY

  if (( emoji_count <= 0 )); then
    REPLY="${(j: :)words}"
    return
  fi

  start_index=$(( token_count - 4 ))
  if (( start_index < 1 )); then
    start_index=1
  fi

  while (( emoji_count > 0 )); do
    rand_range "$start_index" "$token_count"
    position=$REPLY

    if [[ -n ${used_positions[$position]} ]]; then
      continue
    fi

    used_positions[$position]=1
    token="${words[$position]}"
    suffix=''

    if [[ $token[-1] == [.!?] ]]; then
      suffix="${token[-1]}"
    fi

    random_emoji
    emoji="$REPLY"
    words[$position]="${emoji}${suffix}"
    (( emoji_count-- ))
  done

  REPLY="${(j: :)words}"
}

apply_emoji_to_character_text () {
  local text="$1"
  local -i requested_count=$2
  local -i emoji_count=0
  local -i available_length=0
  local tail=''
  local emoji=''
  local separator=' '
  local trimmed=''

  if (( ! emoji_active || ${#emoji_pool[@]} == 0 )); then
    print -- "$text"
    return
  fi

  if (( requested_count <= 2 )); then
    tail=''
    while (( ${#tail} < requested_count )); do
      random_emoji
      tail+="$REPLY"
    done

    print -- "$tail"
    return
  fi

  emoji_count_for_length "$requested_count" 2
  emoji_count=$REPLY

  if (( emoji_count <= 0 )); then
    print -- "$text"
    return
  fi

  while (( emoji_count > 0 )); do
    random_emoji
    emoji="$REPLY"

    if [[ -n $tail ]]; then
      tail+=" "
    fi

    tail+="$emoji"
    (( emoji_count-- ))
  done

  available_length=$(( requested_count - ${#tail} ))

  if (( available_length <= 0 )); then
    print -- "${tail[1,$requested_count]}"
    return
  fi

  if (( available_length <= 4 )); then
    separator=''
  fi

  trimmed="${text[1,$available_length]}"
  trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"

  if [[ -n $trimmed ]]; then
    print -- "${trimmed}${separator}${tail}"
    return
  fi

  print -- "$tail"
}

random_words () {
  local -i requested_count=$1
  local -a words=()
  local -i total=0

  if (( word_length_filter_set )); then
    total=${#filtered_words[@]}
    (( total > 0 )) || die "No words match the requested range"

    while (( ${#words[@]} < requested_count )); do
      rand_range 1 "$total"
      words+=( "${filtered_words[REPLY]}" )
    done
  else
    total=${#dict_words[@]}

    while (( ${#words[@]} < requested_count )); do
      local -i remaining=$(( requested_count - ${#words[@]} ))
      local -i chunk=$remaining

      if (( chunk > total )); then
        chunk=$total
      fi

      local -i max_start=$(( total - chunk + 1 ))
      rand_range 1 "$max_start"
      local -i start=$REPLY
      local -a segment=( $dict_words[$start,$(( start + chunk - 1 ))] )
      words+=( "${segment[@]}" )
    done
  fi

  if (( emoji_active )); then
    apply_emoji_to_words "${words[@]}"
    return
  fi

  REPLY="${(j: :)words}"
}

random_sentence () {
  local -i word_count=$1
  random_words "$word_count"
  REPLY="$(format_text "$REPLY")"
}

build_characters () {
  local -i requested_count=$count
  local source="$dictstring"
  local -i max_start=0
  local -i start=1
  local text=''

  while (( ${#source} < requested_count + 1 )); do
    source+=" $dictstring"
  done

  max_start=$(( ${#source} - requested_count ))

  while :; do
    rand_range 1 "$max_start"
    start=$REPLY
    text="${source[$start,$(( start + requested_count - 1 ))]}"

    if [[ $text[1] != ' ' && $text[-1] != ' ' ]]; then
      break
    fi
  done

  if (( emoji_active )); then
    text="$(apply_emoji_to_character_text "$text" "$requested_count")"
  fi

  REPLY="$(format_text "$text")"
  generated_items=( "$REPLY" )
  generated_text="$REPLY"
}

build_words () {
  random_words "$count"
  REPLY="$(format_text "$REPLY")"
  generated_items=( ${(s: :)REPLY} )
  generated_text="$REPLY"
}

build_lines () {
  local -a lines=()
  local -i index=1
  local output=''
  local line=''

  while (( index <= count )); do
    rand_range "$range_min" "$range_max"
    random_words "$REPLY"
    lines+=( "$(apply_line_prefix "$(format_text "$REPLY")" "$index")" )
    (( index++ ))
  done

  for line in "${lines[@]}"; do
    if [[ -n $output ]]; then
      output+=$'\n'
    fi

    output+="$line"
  done

  REPLY="$output"
  generated_items=( "${lines[@]}" )
  generated_text="$REPLY"
}

build_sentences () {
  local -a sentences=()
  local -i index=1

  while (( index <= count )); do
    rand_range "$range_min" "$range_max"
    random_sentence "$REPLY"
    sentences+=( "$REPLY" )
    (( index++ ))
  done

  REPLY="${(j: :)sentences}"
  generated_items=( "${sentences[@]}" )
  generated_text="$REPLY"
}

build_paragraphs () {
  local -a paragraphs=()
  local -i paragraph_index=1
  local output=''
  local paragraph=''

  while (( paragraph_index <= count )); do
    local -a sentences=()
    local -i sentence_count=0
    local -i sentence_index=1

    rand_range "$range_min" "$range_max"
    sentence_count=$REPLY

    while (( sentence_index <= sentence_count )); do
      rand_range "$paragraph_sentence_word_min" "$paragraph_sentence_word_max"
      random_sentence "$REPLY"
      sentences+=( "$REPLY" )
      (( sentence_index++ ))
    done

    paragraphs+=( "${(j: :)sentences}" )
    (( paragraph_index++ ))
  done

  for paragraph in "${paragraphs[@]}"; do
    if [[ -n $output ]]; then
      output+=$'\n\n'
    fi

    output+="$paragraph"
  done

  REPLY="$output"
  generated_items=( "${paragraphs[@]}" )
  generated_text="$REPLY"
}

build_template () {
  local body=''
  local -a items=()
  local -i index=1
  local output=''
  local item=''

  template_exists "$selected_template" || die "Template not found: $selected_template"
  load_template_body "$selected_template"
  body="$REPLY"

  while (( index <= count )); do
    render_template_text "$body"
    items+=( "$REPLY" )
    (( index++ ))
  done

  for item in "${items[@]}"; do
    if [[ -n $output ]]; then
      output+=$'\n'
    fi

    output+="$item"
  done

  generated_items=( "${items[@]}" )
  generated_text="$output"
  REPLY="$output"
}

