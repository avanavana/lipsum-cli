typeset -i max_sentences=${LIPSUM_MAX_SENTENCES:-10000}
typeset -i max_paragraphs=${LIPSUM_MAX_PARAGRAPHS:-2000}

while (( $# > 0 )); do
  case "$1" in
    --bullets)
      bullets=1
      if read_optional_bulletchar "$2"; then
        shift
      fi
      ;;
    --bullets=*)
      bullets=1
      bulletchar="${1#*=}"
      bulletchar_set=1
      ;;
    --ordered-list)
      ordered_list=1
      if read_optional_ordered_formula "$2"; then
        shift
      fi
      ;;
    --ordered-list=*)
      ordered_list=1
      ordered_formula="${1#*=}"
      ordered_formula_set=1
      ;;
    -r|-R)
      [[ -n $2 ]] || die "Missing range for $1"
      parse_positive_spec "$2" range_min range_max 'length' || die "Invalid length range: $2"
      range_set=1
      shift
      ;;
    -r=*|-R=*)
      parse_positive_spec "${1#*=}" range_min range_max 'length' || die "Invalid length range: ${1#*=}"
      range_set=1
      ;;
    --range)
      [[ -n $2 ]] || die "Missing range for --range"
      parse_positive_spec "$2" range_min range_max 'length' || die "Invalid length range: $2"
      range_set=1
      shift
      ;;
    --range=*)
      parse_positive_spec "${1#*=}" range_min range_max 'length' || die "Invalid length range: ${1#*=}"
      range_set=1
      ;;
    -c|-C|--copy)
      copy_override=1
      ;;
    --no-copy)
      copy_override=0
      ;;
    --no-full-stop)
      punc=0
      ;;
    --source)
      [[ -n $2 ]] || die "Missing source name for --source"
      selected_source="$(normalize_source_name "$2")"
      source_set=1
      shift
      ;;
    --source=*)
      selected_source="$(normalize_source_name "${1#*=}")"
      source_set=1
      ;;
    --text)
      [[ -n $2 ]] || die "Missing text value for --text"
      custom_source_text="$2"
      custom_source_set=1
      shift
      ;;
    --text=*)
      custom_source_text="${1#*=}"
      custom_source_set=1
      ;;
    --file)
      [[ -n $2 ]] || die "Missing file path for --file"
      custom_source_file="$2"
      custom_source_set=1
      shift
      ;;
    --file=*)
      custom_source_file="${1#*=}"
      custom_source_set=1
      ;;
    --save-source)
      [[ -n $2 ]] || die "Missing source name for --save-source"
      save_source_name="$(normalize_source_name "$2")"
      shift
      ;;
    --save-source=*)
      save_source_name="$(normalize_source_name "${1#*=}")"
      ;;
    --lowercase)
      case_mode='lower'
      ;;
    --uppercase)
      case_mode='upper'
      ;;
    --title-case)
      case_mode='title'
      ;;
    --version)
      print_version
      ;;
    --help)
      print_usage
      ;;
    --*)
      die "Illegal option $1"
      ;;
    -?*)
      local cluster="${1#-}"
      local -i index=1

      if [[ -z $cluster || $cluster =~ [^A-Za-z] ]]; then
        die "Illegal option $1"
      fi

      while (( index <= ${#cluster} )); do
        local short_opt="${cluster[index]}"

        case "$short_opt" in
          n|N)
            punc=0
            ;;
          l|L)
            case_mode='lower'
            ;;
          u|U)
            case_mode='upper'
            ;;
          t|T)
            case_mode='title'
            ;;
          b|B)
            bullets=1
            if (( index == ${#cluster} )) && read_optional_bulletchar "$2"; then
              shift
            fi
            ;;
          o|O)
            ordered_list=1
            if (( index == ${#cluster} )) && read_optional_ordered_formula "$2"; then
              shift
            else
              ordered_formula='%d.'
              ordered_formula_set=1
            fi
            ;;
          r|R)
            if (( index != ${#cluster} )); then
              die "Option -$short_opt requires a separate argument"
            fi

            [[ -n $2 ]] || die "Missing range for -$short_opt"
            parse_positive_spec "$2" range_min range_max 'length' || die "Invalid length range: $2"
            range_set=1
            shift
            ;;
          s|S)
            if (( index != ${#cluster} )); then
              die "Option -$short_opt requires a separate argument"
            fi

            [[ -n $2 ]] || die "Missing source name for -$short_opt"
            selected_source="$(normalize_source_name "$2")"
            source_set=1
            shift
            ;;
          c|C)
            copy_override=1
            ;;
          v|V)
            print_version
            ;;
          h|H)
            print_usage
            ;;
          *)
            die "Illegal option -$short_opt"
            ;;
        esac

        (( index++ ))
      done
      ;;
    *)
      if is_action_name "$1"; then
        if (( action_set )); then
          die "Multiple actions specified"
        fi

        set_action_command "$1"
        action_set=1
      elif is_content_command_name "$1"; then
        if (( command_set )); then
          die "Multiple commands specified"
        fi

        set_content_command "$1"
        command_set=1
      elif parse_positive_spec "$1" compact_count_min compact_count_max 'count'; then
        set_count_spec "$1"
      elif parse_compact_token "$1"; then
        :
      else
        die "Unknown argument: $1"
      fi
      ;;
  esac

  shift
done

if (( action_set )); then
  if (( command_set || count_set || source_set || custom_source_set || ${#save_source_name} > 0 || bullets || ordered_list || range_set || copy_override >= 0 || ! punc )) || [[ $case_mode != 'normal' ]]; then
    die "The action '$action_command' cannot be combined with generation options or commands"
  fi

  case "$action_command" in
    init)
      init_config
      ;;
    config)
      open_config
      ;;
  esac
fi

load_config
validate_config

if (( action_set )) && [[ $action_command == 'sources' ]]; then
  print_available_sources
fi

if (( source_set && custom_source_set )); then
  die 'Use either --source or custom source input, not both'
fi

if [[ -n $save_source_name ]] && (( ! custom_source_set )); then
  die '--save-source requires --text or --file input'
fi

if [[ -n $custom_source_text && -n $custom_source_file ]]; then
  die 'Use either --text or --file, not both'
fi

if [[ -n $save_source_name ]]; then
  valid_source_name "$save_source_name" || die "Invalid source name: $save_source_name"
fi

if (( source_set )); then
  resolved_source="$selected_source"
else
  resolved_source="$default_source"
fi

if (( custom_source_set )); then
  if [[ -n $custom_source_file ]]; then
    [[ -r $custom_source_file ]] || die "Source file not found: $custom_source_file"
    custom_source_text="$(<"$custom_source_file")"
  elif [[ $custom_source_text == '-' ]]; then
    custom_source_text="$(cat)"
  fi

  custom_source_text="$(normalize_corpus_text "$custom_source_text")"
  [[ -n $custom_source_text ]] || die 'Custom source text is empty'

  if [[ -n $save_source_name ]]; then
    save_source_text "$save_source_name" "$custom_source_text"
    resolved_source="$save_source_name"
  else
    resolved_source='custom'
  fi

  load_dictionary_from_text "$custom_source_text"
else
  resolve_source_dictionary_path "$resolved_source"
  load_dictionary
fi

if (( command_set )); then
  :
else
  set_content_command "$default_mode"
fi

if (( bulletchar_set )); then
  :
else
  bulletchar="$default_bullet_char"
fi

if (( ordered_list )) && (( ! ordered_formula_set )); then
  ordered_formula="$default_ordered_list_format"
  ordered_formula_set=1
fi

if (( copy_override >= 0 )); then
  copy_enabled=$copy_override
else
  copy_enabled=$copy_on_generate
fi

if (( count_set )); then
  rand_range "$count_min" "$count_max"
  count=$REPLY
else
  default_count_for_command "$content_command"
  count=$REPLY
fi

if (( bullets && ordered_list )); then
  die "Use either bullets or ordered-list, not both"
fi

case "$content_command" in
  words)
    if (( range_set )); then
      local_word_length_min=$range_min
      local_word_length_max=$range_max
    else
      local_word_length_min=$config_word_length_min
      local_word_length_max=$config_word_length_max
    fi

    word_length_filter_set=1
    filtered_words=()

    for word in "${dict_words[@]}"; do
      local -i word_length=${#word}
      if (( word_length >= local_word_length_min && word_length <= local_word_length_max )); then
        filtered_words+=( "$word" )
      fi
    done
    ;;
  lines)
    if (( ! range_set )); then
      range_min=$config_line_range_min
      range_max=$config_line_range_max
    fi

    if (( ordered_list )); then
      parse_ordered_formula "$ordered_formula"
    fi
    ;;
  sentences)
    if (( ! range_set )); then
      range_min=$config_sentence_range_min
      range_max=$config_sentence_range_max
    fi
    ;;
  paragraphs)
    if (( ! range_set )); then
      range_min=$config_paragraph_range_min
      range_max=$config_paragraph_range_max
    fi

    paragraph_sentence_word_min=$config_paragraph_sentence_word_min
    paragraph_sentence_word_max=$config_paragraph_sentence_word_max
    ;;
  characters)
    :
    ;;
esac

if (( ordered_list )) && [[ $content_command != 'lines' ]]; then
  die "--ordered-list is only valid with lines"
fi

case "$content_command" in
  characters)
    (( count <= max_characters )) || die "Character count capped at $max_characters. Set LIPSUM_MAX_CHARACTERS to raise it."
    ;;
  words)
    (( count <= max_words )) || die "Word count capped at $max_words. Set LIPSUM_MAX_WORDS to raise it."
    ;;
  lines)
    (( count <= max_lines )) || die "Line count capped at $max_lines. Set LIPSUM_MAX_LINES to raise it."
    ;;
  sentences)
    (( count <= max_sentences )) || die "Sentence count capped at $max_sentences. Set LIPSUM_MAX_SENTENCES to raise it."
    ;;
  paragraphs)
    (( count <= max_paragraphs )) || die "Paragraph count capped at $max_paragraphs. Set LIPSUM_MAX_PARAGRAPHS to raise it."
    ;;
esac

case "$content_command" in
  characters)
    build_characters
    ;;
  words)
    build_words
    ;;
  lines)
    build_lines
    ;;
  sentences)
    build_sentences
    ;;
  paragraphs)
    build_paragraphs
    ;;
  *)
    die "Unknown command: $content_command"
    ;;
esac

emit_output "$REPLY"
