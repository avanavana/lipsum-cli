      bullets=1
      bulletchar="${1#*=}"
      bulletchar_set=1
      ;;
    --ordered-list)
      ordered_list=1
      if read_optional_ordered_formula "$2"; then
        shift
      fi
      ;;
    --ordered-list=*)
      ordered_list=1
      ordered_formula="${1#*=}"
      ordered_formula_set=1
      ;;
    --punctuation)
      if read_optional_punctuation_mode "$2"; then
        shift
      fi
      ;;
    --punctuation=*)
      valid_punctuation_mode "${1#*=}" || die "Invalid punctuation mode: ${1#*=}"
      punctuation_mode="${1#*=}"
      punctuation_option_set=1
      ;;
    -r|-R)
      [[ -n $2 ]] || die "Missing range for $1"
      parse_positive_spec "$2" range_min range_max 'length' || die "Invalid length range: $2"
      range_set=1
      shift
      ;;
    -r=*|-R=*)
      parse_positive_spec "${1#*=}" range_min range_max 'length' || die "Invalid length range: ${1#*=}"
      range_set=1
      ;;
    --range)
      [[ -n $2 ]] || die "Missing range for --range"
      parse_positive_spec "$2" range_min range_max 'length' || die "Invalid length range: $2"
      range_set=1
      shift
      ;;
    --range=*)
      parse_positive_spec "${1#*=}" range_min range_max 'length' || die "Invalid length range: ${1#*=}"
      range_set=1
      ;;
    -c|-C|--copy)
      copy_override=1
      ;;
    --no-copy)
      copy_override=0
      ;;
    --source)
      [[ -n $2 ]] || die "Missing source name for --source"
      selected_source="$(normalize_source_name "$2")"
      source_set=1
      shift
      ;;
    --source=*)
      selected_source="$(normalize_source_name "${1#*=}")"
      source_set=1
      ;;
    --text)
      [[ -n $2 ]] || die "Missing text value for --text"
      custom_source_text="$2"
      custom_source_set=1
      shift
      ;;
    --text=*)
      custom_source_text="${1#*=}"
      custom_source_set=1
      ;;
    --file)
      [[ -n $2 ]] || die "Missing file path for --file"
      custom_source_file="$2"
      custom_source_set=1
      shift
      ;;
    --file=*)
      custom_source_file="${1#*=}"
      custom_source_set=1
      ;;
    --save-source)
      [[ -n $2 ]] || die "Missing source name for --save-source"
      save_source_name="$(normalize_source_name "$2")"
      shift
      ;;
    --save-source=*)
      save_source_name="$(normalize_source_name "${1#*=}")"
      ;;
    --format)
      [[ -n $2 ]] || die "Missing format for --format"
      valid_output_format "$2" || die "Invalid output format: $2"
      output_format="$2"
      shift
      ;;
    --format=*)
      valid_output_format "${1#*=}" || die "Invalid output format: ${1#*=}"
      output_format="${1#*=}"
      ;;
    --emoji)
      emoji_override=1
      ;;
    --no-emoji)
      emoji_override=0
      ;;
    --lowercase)
      case_mode='lower'
      ;;
    --uppercase)
      case_mode='upper'
      ;;
    --title-case)
      case_mode='title'
      ;;
    --version)
      print_version
      ;;
    --help)
      print_usage
      ;;
    --*)
      die "Illegal option $1"
      ;;
    -?*)
      local cluster="${1#-}"
      local -i index=1

      if [[ -z $cluster || $cluster =~ [^A-Za-z] ]]; then
        die "Illegal option $1"
      fi

      while (( index <= ${#cluster} )); do
        local short_opt="${cluster[index]}"

        case "$short_opt" in
          l|L)
            case_mode='lower'
            ;;
          u|U)
            case_mode='upper'
            ;;
          t|T)
            case_mode='title'
            ;;
          b|B)
            bullets=1
            if (( index == ${#cluster} )) && read_optional_bulletchar "$2"; then
              shift
            fi
            ;;
          o|O)
            ordered_list=1
            if (( index == ${#cluster} )) && read_optional_ordered_formula "$2"; then
              shift
            else
              ordered_formula='%d.'
              ordered_formula_set=1
            fi
            ;;
          p|P)
            if (( index == ${#cluster} )) && read_optional_punctuation_mode "$2"; then
              shift
            else
              punctuation_mode='all'
              punctuation_option_set=1
            fi
            ;;
          r|R)
            if (( index != ${#cluster} )); then
              die "Option -$short_opt requires a separate argument"
            fi

            [[ -n $2 ]] || die "Missing range for -$short_opt"
            parse_positive_spec "$2" range_min range_max 'length' || die "Invalid length range: $2"
            range_set=1
            shift
            ;;
          e|E)
            emoji_override=1
            ;;
          f|F)
            if (( index != ${#cluster} )); then
              die "Option -$short_opt requires a separate argument"
            fi

            [[ -n $2 ]] || die "Missing format for -$short_opt"
            valid_output_format "$2" || die "Invalid output format: $2"
            output_format="$2"
            shift
            ;;
          s|S)
            if (( index != ${#cluster} )); then
              die "Option -$short_opt requires a separate argument"
            fi

            [[ -n $2 ]] || die "Missing source name for -$short_opt"
            selected_source="$(normalize_source_name "$2")"
            source_set=1
            shift
            ;;
          c|C)
            copy_override=1
            ;;
          v|V)
            print_version
            ;;
          h|H)
            print_usage
            ;;
          *)
            die "Illegal option -$short_opt"
            ;;
        esac

        (( index++ ))
      done
      ;;
	    *)
      if [[ $content_command == 'template' && -z $selected_template ]]; then
        selected_template="$(normalize_source_name "$1")"
      elif is_action_name "$1"; then
	        if (( action_set )); then
	          die "Multiple actions specified"
	        fi

        set_action_command "$1"
        action_set=1
      elif is_content_command_name "$1"; then
        if (( command_set )); then
          die "Multiple commands specified"
        fi

        set_content_command "$1"
        command_set=1
      elif parse_positive_spec "$1" compact_count_min compact_count_max 'count'; then
        set_count_spec "$1"
      elif parse_compact_token "$1"; then
        :
      else
        die "Unknown argument: $1"
      fi
      ;;
  esac

  shift
done

